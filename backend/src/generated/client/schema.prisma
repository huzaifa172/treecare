// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client" // 👈 Add this line
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String    @db.VarChar(100)
  email              String    @unique @db.VarChar(255)
  password           String    @db.VarChar(255)
  profilePicture     String?   @db.VarChar(500)
  bio                String?   @db.Text
  greenPoints        Int       @default(0)
  isProfilePublic    Boolean   @default(true)
  emailNotifications Boolean   @default(true)
  city               String?   @db.VarChar(100)
  country            String?   @db.VarChar(100)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastLoginAt        DateTime?

  // Relations
  trees         Tree[]
  adoptions     TreeAdoption[]     @relation("UserAdoptions")
  transfers     TreeAdoption[]     @relation("UserTransfers")
  updates       TreeUpdate[]
  badges        UserBadge[]
  rewards       RewardRedemption[]
  notifications Notification[]
  certificates  Certificate[]

  @@map("users")
}

model Tree {
  id                  String       @id @default(uuid()) @db.Uuid
  qrCode              String       @unique @db.VarChar(50)
  species             String       @db.VarChar(100)
  source              TreeSource
  commitmentDuration  Int // in months
  initialHealthStatus HealthStatus
  currentHealthStatus HealthStatus @default(HEALTHY)
  location            Json // {latitude, longitude, address}
  photoUrl            String       @db.VarChar(500)
  plantedAt           DateTime     @default(now())
  isActive            Boolean      @default(true)
  isAdoptable         Boolean      @default(false)
  transferReason      String?      @db.Text
  lastUpdateAt        DateTime?

  // Owner relations
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Relations
  updates      TreeUpdate[]
  adoptions    TreeAdoption[]
  certificates Certificate[]

  @@index([ownerId])
  @@index([species])
  @@index([plantedAt])
  @@index([isAdoptable])
  @@map("trees")
}

model TreeUpdate {
  id                 String       @id @default(uuid()) @db.Uuid
  healthStatus       HealthStatus
  notes              String?      @db.Text
  photoUrl           String       @db.VarChar(500)
  growthMeasurements Json? // {height, trunk_diameter, canopy_width}
  gpsLocation        Json? // verification of current location
  createdAt          DateTime     @default(now())

  // Relations
  treeId String @db.Uuid
  tree   Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([treeId])
  @@index([createdAt])
  @@map("tree_updates")
}

model TreeAdoption {
  id                 String   @id @default(uuid()) @db.Uuid
  reason             String?  @db.Text
  commitmentMessage  String?  @db.Text
  commitmentDuration Int? // in months
  adoptedAt          DateTime @default(now())

  // Relations
  treeId          String @db.Uuid
  tree            Tree   @relation(fields: [treeId], references: [id], onDelete: Cascade)
  previousOwnerId String @db.Uuid
  previousOwner   User   @relation("UserTransfers", fields: [previousOwnerId], references: [id])
  newOwnerId      String @db.Uuid
  newOwner        User   @relation("UserAdoptions", fields: [newOwnerId], references: [id])

  @@index([treeId])
  @@index([adoptedAt])
  @@map("tree_adoptions")
}

model Badge {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @unique @db.VarChar(100)
  description String        @db.Text
  icon        String        @db.VarChar(10)
  category    BadgeCategory
  requirement Json // criteria for earning badge
  pointsValue Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  // Relations
  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid()) @db.Uuid
  earnedAt DateTime @default(now())

  // Relations
  userId  String @db.Uuid
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId String @db.Uuid
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model Reward {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @db.VarChar(200)
  description String         @db.Text
  pointsCost  Int
  category    RewardCategory
  imageUrl    String?        @db.VarChar(500)
  inStock     Boolean        @default(true)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())

  // Relations
  redemptions RewardRedemption[]

  @@map("rewards")
}

model RewardRedemption {
  id              String           @id @default(uuid()) @db.Uuid
  pointsSpent     Int
  shippingAddress Json? // address object
  status          RedemptionStatus @default(PENDING)
  redeemedAt      DateTime         @default(now())
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // Relations
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId String @db.Uuid
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([redeemedAt])
  @@map("reward_redemptions")
}

model Certificate {
  id       String          @id @default(uuid()) @db.Uuid
  type     CertificateType
  pdfUrl   String          @db.VarChar(500)
  metadata Json // certificate data
  issuedAt DateTime        @default(now())

  // Relations
  userId String  @db.Uuid
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  treeId String? @db.Uuid
  tree   Tree?   @relation(fields: [treeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([issuedAt])
  @@map("certificates")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(200)
  message   String           @db.Text
  data      Json? // additional notification data
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relations
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model LearningModule {
  id           String     @id @default(uuid()) @db.Uuid
  title        String     @db.VarChar(200)
  description  String     @db.Text
  content      Json // structured learning content
  duration     Int // in minutes
  difficulty   Difficulty
  topics       String[] // array of topic tags
  thumbnailUrl String?    @db.VarChar(500)
  isActive     Boolean    @default(true)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([difficulty])
  @@index([isActive, order])
  @@map("learning_modules")
}

model GlobalStats {
  id              String   @id @default(uuid()) @db.Uuid
  totalTrees      Int      @default(0)
  totalUsers      Int      @default(0)
  totalUpdates    Int      @default(0)
  totalAdoptions  Int      @default(0)
  co2OffsetKg     Float    @default(0)
  countriesActive Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@map("global_stats")
}

// Enums
enum TreeSource {
  NURSERY
  HOMEGROWN
  GRAFTED
  WILD_SEEDLING
}

enum HealthStatus {
  EXCELLENT
  HEALTHY
  GOOD
  FAIR
  POOR
  CRITICAL
  DEAD
}

enum BadgeCategory {
  STARTER
  GROWTH
  CARE
  COMMUNITY
  IMPACT
  SPECIAL
}

enum RewardCategory {
  MERCHANDISE
  DISCOUNTS
  EVENTS
  DIGITAL
  PHYSICAL
}

enum RedemptionStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum CertificateType {
  TREE_OWNERSHIP
  ADOPTION
  ACHIEVEMENT
  PARTICIPATION
}

enum NotificationType {
  TREE_UPDATE_REMINDER
  ADOPTION_REQUEST
  BADGE_EARNED
  POINT_MILESTONE
  SYSTEM_UPDATE
  COMMUNITY_NEWS
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}
